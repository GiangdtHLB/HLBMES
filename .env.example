# MES Nhà máy Bia — biến môi trường (copy thành .env và chỉnh)

# --- Database ---
# Dev (mặc định, không cần đặt): SQLite tại backend/mes.db
# Production: trỏ DB ngoài qua MES_DATABASE_URL (chọn 1):
#   PostgreSQL:  MES_DATABASE_URL=postgresql+psycopg://mes:mes_secret@db:5432/mes
#   SQL Server:  MES_DATABASE_URL=mssql+pyodbc://mes:mes_secret@sqlsrv:1433/MES?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes
# (SQL Server cần cài 'ODBC Driver 18 for SQL Server' + pip install pyodbc ở máy chạy app.)
# MES_DATABASE_URL=
POSTGRES_PASSWORD=doi_mat_khau_nay
# Tự tạo bảng bằng create_all. SQLite luôn tự tạo; Postgres/SQL Server CHỈ tạo khi =1.
# Production: ĐỂ 0 và dùng `alembic upgrade head` làm nguồn schema duy nhất.
MES_AUTO_CREATE=0
MES_DB_POOL_SIZE=10
MES_DB_MAX_OVERFLOW=20

# --- Trợ lý AI (tùy chọn) ---
# Có key → trợ lý dùng Claude thật (claude-opus-4-8); không có → engine luật offline.
ANTHROPIC_API_KEY=
MES_LLM_ENABLED=auto          # auto | on | off
MES_LLM_MODEL=claude-opus-4-8

# --- Edge OPC UA (line chiết / PLC-SCADA) ---
# Trỏ tới OPC UA server thật rồi chạy:  python -m app.opcua_edge
# Demo không cần PLC (tự dựng server WS cục bộ):  python -m app.opcua_edge --demo
MES_OPCUA_URL=                # vd opc.tcp://192.168.0.10:4840
# Khóa API cho edge/ERP. ĐỂ TRỐNG khi seed → hệ tự sinh key ngẫu nhiên & in ra một lần;
# copy giá trị đó vào đây để edge/ERP dùng cố định (KHÔNG dùng lại key demo cũ).
MES_EDGE_KEY=
MES_DEMO_READ_KEY=
EDGE_INTERVAL=3

# --- Bảo mật ---
# CHỈ bật ở dev: cho phép xác thực dự phòng bằng header X-User/X-Role (bỏ qua đăng nhập).
# Production PHẢI để 0 hoặc bỏ trống.
MES_DEV_HEADER_AUTH=0
# Mật khẩu admin khởi tạo. ĐẶT giá trị riêng cho production (nếu bỏ trống sẽ dùng
# 'admin123' và BUỘC đổi mật khẩu lần đăng nhập đầu).
MES_ADMIN_PASSWORD=
MES_SESSION_HOURS=12

# --- Seed dữ liệu demo ---
# Production: ĐẶT 0 → chỉ tạo admin, KHÔNG tạo tài khoản/API key/dữ liệu demo.
# Dev: 1 (mặc định) → seed đầy đủ tài khoản & dữ liệu mẫu.
MES_SEED_DEMO=1

# --- Rate-limit / quota (chống brute-force & lạm dụng AI = chi phí) ---
MES_RL_ENABLED=1
MES_RL_LOGIN_PER_MIN=10        # số lần đăng nhập / phút / IP
MES_RL_AI_PER_MIN=20           # số request AI / phút / phiên
MES_AI_DAILY_QUOTA=300         # số lượt chat AI / ngày / phiên

# --- Logging ---
MES_LOG_LEVEL=INFO
MES_LOG_JSON=0                 # 1 = log JSON (cho thu thập tập trung: Loki/ELK)

# --- Web hardening (production) ---
# Chạy sau reverse proxy TLS (nginx/Caddy) → bật để tin X-Forwarded-For + gửi HSTS.
MES_TRUSTED_PROXY=0
MES_HSTS=0                     # 1 khi đã có HTTPS (gửi Strict-Transport-Security)
# Chỉ đặt nếu frontend phục vụ từ origin KHÁC (mặc định same-origin → để trống, không bật CORS).
MES_CORS_ORIGINS=             # vd https://mes.nhamaybia.local,https://kiosk.local
