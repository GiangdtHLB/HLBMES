# MES Nhà máy Bia — biến môi trường (copy thành .env và chỉnh)

# --- Database ---
# Dev (mặc định, không cần đặt): SQLite tại backend/mes.db
# Production (docker compose): tự đặt qua compose. Hoặc trỏ DB ngoài:
# MES_DATABASE_URL=postgresql+psycopg://mes:mes_secret@db:5432/mes
POSTGRES_PASSWORD=doi_mat_khau_nay

# --- Trợ lý AI (tùy chọn) ---
# Có key → trợ lý dùng Claude thật (claude-opus-4-8); không có → engine luật offline.
ANTHROPIC_API_KEY=
MES_LLM_ENABLED=auto          # auto | on | off
MES_LLM_MODEL=claude-opus-4-8

# --- Bảo mật ---
# CHỈ bật ở dev: cho phép xác thực dự phòng bằng header X-User/X-Role (bỏ qua đăng nhập).
# Production PHẢI để 0 hoặc bỏ trống.
MES_DEV_HEADER_AUTH=0
