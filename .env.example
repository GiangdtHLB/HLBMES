# MES Nhà máy Bia — biến môi trường mẫu.
# Copy thành .env và chỉnh. KHÔNG commit .env thật (đã nằm trong .gitignore).

# --- Database (bắt buộc) ---
# compose dùng để đặt mật khẩu Postgres + dựng MES_DATABASE_URL.
# Không có giá trị mặc định: thiếu biến này `docker compose` sẽ báo lỗi và dừng.
POSTGRES_PASSWORD=change_me_strong_password

# --- Trợ lý AI (tùy chọn) ---
# Có key + cài 'anthropic' → dùng Claude thật; không → engine luật offline.
ANTHROPIC_API_KEY=
MES_LLM_ENABLED=off          # off | auto | on

# --- Bảo mật ---
# Production PHẢI để 0: tắt xác thực dự phòng X-User/X-Role (bypass đăng nhập).
MES_DEV_HEADER_AUTH=0

# --- Địa chỉ bind cổng app trên host ---
# Mặc định 127.0.0.1 (chỉ loopback — an toàn). Đặt 0.0.0.0 nếu cần truy cập qua
# LAN và/hoặc Cloudflare Tunnel (lúc đó phải có firewall/Access bảo vệ).
MES_BIND=127.0.0.1

# --- Seed demo ---
# 1 = nạp dữ liệu + tài khoản/API key DEMO (chỉ dev/UAT local).
# Public/production PHẢI để 0 (không bật lại tài khoản/API key demo).
MES_SEED_DEMO=1
